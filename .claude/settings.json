{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "extraKnownMarketplaces": {
    "ranjit-agent-skills": {
      "source": { "source": "github", "repo": "ranjitjana027/skills" }
    }
  },
  "enabledPlugins": {
    "python-style@ranjit-agent-skills": true,
    "langgraph-skills@ranjit-agent-skills": true
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/protect-files.py\""
          }
        ]
      }
    ]
  }
}
